rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isParticipant(participants) {
      return signedIn() && request.auth.uid in participants;
    }

    function listingDoc(listingId) {
      return get(/databases/$(database)/documents/listings/$(listingId));
    }

    function chatDoc(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId));
    }

    function validChatCreate() {
      return signedIn()
        && request.resource.data.keys().hasAll(['participants', 'listingId', 'sellerId', 'buyerId', 'lastUpdated'])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.sellerId in request.resource.data.participants
        && request.resource.data.buyerId in request.resource.data.participants
        && request.resource.data.sellerId != request.auth.uid
        && request.resource.data.listingId is string
        && exists(/databases/$(database)/documents/listings/$(request.resource.data.listingId))
        && listingDoc(request.resource.data.listingId).data.ownerId == request.resource.data.sellerId;
    }

    function validChatUpdate() {
      return isParticipant(resource.data.participants)
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.listingId == resource.data.listingId
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.buyerId == resource.data.buyerId
        && request.resource.data.lastSenderId == request.auth.uid;
    }

    function isParentChatParticipant(chatId) {
      return signedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in chatDoc(chatId).data.participants;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;

      match /favorites/{listingId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow get: if signedIn()
        && (
          !exists(/databases/$(database)/documents/chats/$(chatId))
          || isParticipant(resource.data.participants)
        );
      allow list: if false;
      allow create: if validChatCreate();
      allow update: if validChatUpdate();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParentChatParticipant(chatId);
        allow create: if isParentChatParticipant(chatId)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }
  }
}
